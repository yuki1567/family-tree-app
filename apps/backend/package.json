{
	"name": "backend",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
		"start": "node dist/index.js",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.4",
		"hono": "^4.12.25",
		"shared": "workspace:*",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"esbuild": "^0.28.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
